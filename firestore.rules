rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function userRole() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
        : null;
    }
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { return isSignedIn() && userRole() == 'admin'; }
    function isBeheerder() { return isSignedIn() && (userRole() == 'beheerder' || isAdmin()); }
    function isActivated() { return isSignedIn() && userRole() != null && userRole() != 'pending'; }

    match /users/{uid} {
      // Geactiveerde gebruikers mogen elkaars profiel lezen (owner-selectie,
      // collectie-browsing). Eigen profiel + admin altijd.
      allow read: if isSignedIn() && (request.auth.uid == uid || isActivated());
      allow create: if isSignedIn() && request.auth.uid == uid;
      // Admin mag alles. Een gebruiker mag zijn eigen profiel bijwerken
      // (pincode, collectionLabel, collectionVisibility, displayName) maar
      // NOOIT zijn eigen rol wijzigen.
      allow update: if isAdmin()
        || (isSignedIn() && request.auth.uid == uid
            && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']));
    }

    match /collectionGrants/{id} {
      // Toegang verlenen om een private collectie te bekijken.
      allow read: if isActivated();
      allow create: if isSignedIn()
        && request.resource.data.granterUid == request.auth.uid;
      allow delete: if isSignedIn()
        && (resource.data.granterUid == request.auth.uid || isAdmin());
    }

    match /records/{id} {
      allow read: if isActivated();
      allow create: if isBeheerder();
      allow update: if isBeheerder();
      allow delete: if isBeheerder();
    }

    match /wishlist/{id} {
      allow read: if isActivated();
      allow create, update, delete: if isBeheerder();
    }

    match /mail/{id} {
      allow read, write: if false;
    }
  }
}
