rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function userRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { return isSignedIn() && userRole() == 'admin'; }
    function isBeheerder() { return isSignedIn() && (userRole() == 'beheerder' || isAdmin()); }
    function isActivated() { return isSignedIn() && userRole() != 'pending'; }

    match /users/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      allow create: if isSignedIn() && request.auth.uid == uid;
      allow update: if isAdmin();
    }

    match /records/{id} {
      allow read: if isActivated();
      allow create: if isBeheerder();
      allow update: if isBeheerder();
      allow delete: if isBeheerder();
    }

    match /wishlist/{id} {
      allow read: if isActivated();
      allow create, update, delete: if isBeheerder();
    }

    match /mail/{id} {
      allow read, write: if false;
    }
  }
}
